@page "/admin"
@page "/admin/usuarios"

<div class="min-h-screen bg-slate-50 p-8">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-4xl font-bold text-slate-900 tracking-tight">Gestión de usuarios</h1>
                <p class="text-slate-500 mt-2 text-sm max-w-2xl">Administrar el acceso al sistema, los protocolos de seguridad y los roles organizacionales del equipo médico de Piedra Azul.</p>
            </div>

            <div class="flex items-center gap-3">
                <a href="/admin/agenda" class="bg-slate-800 hover:bg-slate-900 text-white px-5 py-2.5 rounded-lg font-medium transition-colors shadow-sm flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783" />
                    </svg>
                    Agendador
                </a>

                <a href="/admin/configurar-horario" class="bg-slate-800 hover:bg-slate-900 text-white px-5 py-2.5 rounded-lg font-medium transition-colors shadow-sm flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1z" />
                        <path d="M18 9H2v7a2 2 0 002 2h12a2 2 0 002-2V9zm-9 2a1 1 0 012 0v1h1a1 1 0 110 2h-1v1a1 1 0 11-2 0v-1H8a1 1 0 110-2h1v-1z" />
                    </svg>
                     Horarios
                </a>
                <button class="bg-teal-700 hover:bg-teal-800 text-white px-5 py-2.5 rounded-lg font-medium transition-colors shadow-sm flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6zM16 7a1 1 0 10-2 0v1h-1a1 1 0 100 2h1v1a1 1 0 102 0v-1h1a1 1 0 100-2h-1V7z" />
                    </svg>
                    Usuarios
                </button>
            </div>
        </div>

        <!-- Panel de Filtros -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 mb-6 flex flex-wrap gap-6 items-end">
            <div class="flex-grow min-w-[250px]">
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Buscar Usuario</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <input type="text" class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg pl-10 pr-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-teal-500/50" placeholder="Filtrar por nombre, identificación, cel..." />
                </div>
            </div>
            
            <div class="w-48">
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Rol</label>
                <select class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-teal-500/50 appearance-none">
                    <option>Todos los Roles</option>
                    <option>Doctor/Terapista</option>
                    <option>Agendador</option>
                    <option>Administrador</option>
                </select>
            </div>
            
            <div class="w-48">
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Fecha</label>
                <div class="relative">
                    <input type="text" class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg pl-4 pr-10 py-2.5 focus:outline-none focus:ring-2 focus:ring-teal-500/50" placeholder="dd/mm/aaaa" />
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                </div>
            </div>

            <div>
                <button class="text-teal-600 hover:text-teal-800 font-semibold text-sm transition-colors py-2.5 px-2">Limpiar<br />Filtros</button>
            </div>
        </div>

        <!-- Tabla Principal -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden mb-8">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-100">
                            <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider">Nombre</th>
                            <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider">Login / User</th>
                            <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider">Rol</th>
                            <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider">Estado</th>
                            <th class="py-4 px-6 text-xs font-bold text-slate-400 uppercase tracking-wider text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        
                        <!-- Usuario Doctor -->
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="py-5 px-6">
                                <div class="font-bold text-slate-900 text-base">Dr. Roberto Gómez</div>
                                <div class="text-sm text-teal-600 font-medium mt-0.5 flex items-center gap-1 cursor-pointer">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                    Mirar registro medico
                                </div>
                            </td>
                            <td class="py-5 px-6 text-slate-500 font-mono text-sm">rgomez_pa</td>
                            <td class="py-5 px-6">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-bold border border-blue-100">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
                                    Doctor/Terapista
                                </span>
                            </td>
                            <td class="py-5 px-6">
                                <span class="inline-flex px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold">
                                    ACTIVO
                                </span>
                            </td>
                            <td class="py-5 px-6">
                                <div class="flex items-center justify-center gap-3">
                                    <button class="text-slate-400 hover:text-teal-600 transition-colors">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                    </button>
                                    <button class="text-rose-400 hover:text-rose-600 transition-colors">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6" /></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>

                        <!-- Usuario Agendador -->
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="py-5 px-6">
                                <div class="font-bold text-slate-900 text-base">Ana Martínez</div>
                            </td>
                            <td class="py-5 px-6 text-slate-500 font-mono text-sm">amartinez</td>
                            <td class="py-5 px-6">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-purple-50 text-purple-600 text-xs font-bold border border-purple-100">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                    Agendador
                                </span>
                            </td>
                            <td class="py-5 px-6">
                                <span class="inline-flex px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold">
                                    ACTIVO
                                </span>
                            </td>
                            <td class="py-5 px-6">
                                <div class="flex items-center justify-center gap-3">
                                    <button class="text-slate-400 hover:text-teal-600 transition-colors">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                    </button>
                                    <button class="text-rose-400 hover:text-rose-600 transition-colors">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6" /></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>

                        <!-- Usuario Admin -->
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="py-5 px-6">
                                <div class="font-bold text-slate-900 text-base">Carlos Ruiz</div>
                            </td>
                            <td class="py-5 px-6 text-slate-500 font-mono text-sm">cruiz_admin</td>
                            <td class="py-5 px-6">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 text-amber-600 text-xs font-bold border border-amber-100">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                                    Administrador
                                </span>
                            </td>
                            <td class="py-5 px-6">
                                <span class="inline-flex px-3 py-1 rounded-full bg-slate-100 text-slate-500 text-xs font-bold">
                                    INACTIVO
                                </span>
                            </td>
                            <td class="py-5 px-6">
                                <div class="flex items-center justify-center gap-3">
                                    <button class="text-slate-400 hover:text-teal-600 transition-colors">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                    </button>
                                    <button class="text-emerald-500 hover:text-emerald-700 transition-colors">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" /></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        
                    </tbody>
                </table>
            </div>

            <!-- Paginación Mock -->
            <div class="p-4 border-t border-slate-100 flex items-center justify-between">
                <div class="text-sm text-slate-500">Mostrando <span class="font-bold text-slate-700">1-10</span> de <span class="font-bold text-slate-700">42</span> usuarios</div>
                <div class="flex items-center gap-1">
                    <button class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:bg-slate-50 transition-colors">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                    </button>
                    <button class="w-8 h-8 flex items-center justify-center rounded-lg bg-teal-700 text-white font-medium text-sm">1</button>
                    <button class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-600 hover:bg-slate-50 font-medium text-sm transition-colors">2</button>
                    <button class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-600 hover:bg-slate-50 font-medium text-sm transition-colors">3</button>
                    <button class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:bg-slate-50 transition-colors">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </button>
                </div>
            </div>
        </div>
        <!-- Panel de Creación Rápida -->
        <div class="bg-teal-50/50 rounded-2xl p-8 border border-teal-100 relative overflow-hidden">
            <!-- Icon Background Decoration -->
            <div class="absolute -right-8 -bottom-16 text-teal-100/50 pointer-events-none">
                <svg class="w-64 h-64" fill="currentColor" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>

            <div class="relative z-10">
                <div class="flex items-center gap-4 mb-8">
                    <div class="bg-teal-700 text-white p-3 rounded-xl shadow-sm">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" /></svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold text-slate-900">Creación rápida de nuevo usuario</h2>
                        <p class="text-slate-600 text-sm mt-1">Proporcionar nuevas cuentas de personal con permisos de roles especializados.</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Nombre completo</label>
                        <input type="text" class="w-full bg-white border border-slate-200 text-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-teal-500/50 placeholder-slate-400 shadow-sm" placeholder="e.g. Elena Soprano" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Número de teléfono</label>
                        <input type="text" class="w-full bg-white border border-slate-200 text-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-teal-500/50 placeholder-slate-400 shadow-sm" placeholder="301-1234567" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Contraseña generada</label>
                        <div class="relative">
                            <input type="password" class="w-full bg-white border border-slate-200 text-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-teal-500/50 shadow-sm" value="********" readonly />
                            <button class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-teal-600 transition-colors">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="flex items-end gap-6">
                    <div class="flex-grow max-w-[calc(33.333%-1rem)]">
                        <label class="block text-sm font-bold text-slate-700 mb-2">Rol en el Sistema</label>
                        <select class="w-full bg-white border border-slate-200 text-slate-700 rounded-lg px-4 py-3 outline-none focus:ring-2 focus:ring-teal-500/50 appearance-none shadow-sm">
                            <option>Seleccione un rol...</option>
                            <option>Doctor/Terapista</option>
                            <option>Agendador</option>
                            <option>Administrador</option>
                        </select>
                    </div>
                    
                    <div class="flex-grow max-w-[calc(33.333%-1rem)]">
                        <label class="block text-sm font-bold text-slate-700 mb-2">Estado de cuenta</label>
                        <div class="flex items-center gap-3 py-2">
                            <button class="relative inline-flex h-6 w-11 items-center rounded-full bg-teal-600 transition-colors focus:outline-none focus:ring-2 focus:ring-teal-500 focus:ring-offset-2">
                                <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform translate-x-6"></span>
                            </button>
                            <span class="text-sm font-bold text-slate-900">Active Access</span>
                        </div>
                    </div>

                    <div class="flex-grow">
                        <button class="w-full bg-teal-700 hover:bg-teal-800 text-white px-6 py-3 rounded-lg font-bold transition-colors shadow-md text-[15px]">
                            Confirmar y Crear Usuario
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
}
