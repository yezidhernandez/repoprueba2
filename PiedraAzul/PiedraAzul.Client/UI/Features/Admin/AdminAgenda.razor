@page "/admin/agenda"
@using PiedraAzul.Client.Models.GraphQL
@using PiedraAzul.Contracts.Enums
@inject PiedraAzul.Client.Services.GraphQLServices.GraphQLAppointmentService AppointmentService
@inject PiedraAzul.Client.Services.GraphQLServices.GraphQLDoctorService DoctorService

<div class="min-h-screen bg-slate-50 p-8">
    <div class="mx-auto max-w-7xl">
        
        <!-- Header -->
        <div class="mb-8 flex items-center justify-between">
            <div>
                <h1 class="text-4xl font-black text-slate-900">Agenda Médica</h1>
                <p class="mt-1 text-slate-500 font-medium">Gestión y listado de citas de los especialistas</p>
            </div>
            
            <div class="flex items-center gap-4">
                <a href="/admin/configurar-horario" class="flex items-center gap-2 rounded-xl border-2 border-primary/20 bg-white px-6 py-2.5 font-bold text-primary shadow-sm transition-all hover:border-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"/><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
                    Configurar Horario
                </a>

                <a href="/booking/manual" class="flex items-center gap-2 rounded-xl bg-primary px-6 py-2.5 font-bold text-white shadow-lg shadow-primary/20 transition-all hover:opacity-90">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                    Agendar Manualmente
                </a>
            </div>
        </div>

        <!-- Filtros -->
        <div class="mb-6 grid grid-cols-1 gap-4 rounded-2xl border border-slate-100 bg-white p-5 shadow-sm md:grid-cols-3">
            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Especialista</label>
                <select class="w-full rounded-lg border border-slate-200 bg-slate-50 px-4 py-2.5 text-slate-700 focus:outline-none focus:ring-2 focus:ring-teal-500/50" @bind="SelectedDoctorId">
                    <option value="">Selecciona un médico...</option>
                    @foreach (var doc in doctores)
                    {
                        <option value="@doc.UserId">@doc.Name (@doc.Specialty)</option>
                    }

                </select>
            </div>
            
            <div>
                <label class="mb-2 block text-sm font-semibold text-slate-700">Fecha</label>
                <input type="date" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-4 py-2.5 text-slate-700 focus:outline-none focus:ring-2 focus:ring-teal-500/50" value="@SelectedDate.ToString("yyyy-MM-dd")" @onchange="OnDateChange" />
            </div>

            <div class="flex items-end">
                <button class="w-full rounded-lg bg-slate-800 px-4 py-2.5 font-medium text-white shadow-sm transition-colors hover:bg-slate-900" @onclick="CargarCitas">
                    Filtrar Agenda
                </button>
            </div>
        </div>

        <!-- Tabla de Citas -->
        <div class="overflow-hidden rounded-2xl border border-slate-100 bg-white shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full border-collapse text-left">
                    <thead>
                        <tr class="border-b border-slate-100 bg-slate-50/50">
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-slate-500">Hora</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-slate-500">Paciente</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-slate-500">Motivo/Servicio</th>
                            <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-slate-500">Estado</th>
                            <th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-slate-500">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @if (citas == null || !citas.Any())
                        {
                            <tr><td colspan="5" class="py-6 text-center text-slate-500">No hay citas para mostrar en esta fecha o seleccione un médico.</td></tr>
                        }
                        else
                        {
                            @foreach (var cita in citas)
                            {
                                <tr class="transition-colors hover:bg-slate-50/50">
                                     <td class="px-6 py-4">
                                         <div class="font-semibold text-slate-800">
                                             @cita.Start.ToString("hh:mm tt")
                                         </div>
                                     </td>
                                     <td class="px-6 py-4">
                                         <div class="font-medium text-slate-900">@cita.PatientName</div>
                                         <div class="text-sm text-slate-500">Tipo: @cita.PatientType</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700">Consulta Médica</div>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center gap-1.5 rounded-full border border-amber-200/50 bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700">
                                            <span class="h-1.5 w-1.5 rounded-full bg-amber-500"></span>
                                            Confirmada
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <button class="mr-3 text-sm font-medium text-teal-600 transition-colors hover:text-teal-800">Ver Detalle</button>
                                        <button class="text-sm font-medium text-rose-500 transition-colors hover:text-rose-700">Cancelar</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            
            <!-- Paginación -->
            <div class="flex items-center justify-between border-t border-slate-100 p-4 text-sm text-slate-500">
                <div>Mostrando resultados del médico</div>
            </div>
        </div>

    </div>
</div>

@code {
    private List<DoctorGQL> doctores = new();
    private List<AppointmentGQL> citas = new();
    private string SelectedDoctorId { get; set; } = "";
    private DateTime SelectedDate { get; set; } = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        for (int i = 0; i <= 3; i++)
        {
            var type = (DoctorType)i;

            var result = await DoctorService.GetDoctorsByTypeAsync(
                type.ToGraphQL()
            );

            if (result.Any())
                doctores.AddRange(result);
        }
    }

    private void OnDateChange(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var parsedDate))
            SelectedDate = parsedDate;
    }

    private async Task CargarCitas()
    {
        if (string.IsNullOrEmpty(SelectedDoctorId)) return;

        var result = await AppointmentService.GetDoctorAppointments(SelectedDoctorId, SelectedDate);
        if (result.IsSuccess && result.Value != null)
            citas = result.Value;
    }
}
