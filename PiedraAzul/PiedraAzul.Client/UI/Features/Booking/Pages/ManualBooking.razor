@page "/booking/manual"
@using PiedraAzul.Client.Models.Booking
@using PiedraAzul.Client.Models.UserProfiles
@using PiedraAzul.Client.Services.GraphQLServices
@using PiedraAzul.Client.Services.Utils
@using PiedraAzul.Client.UI.Features.Booking.Components
@using PiedraAzul.Client.UI.Shared.Components

@inject GraphQLPatientService PatientService
@inject GraphQLAppointmentService AppointmentService

<!-- <AuthorizeGuard RequiredRole="Doctor" ReturnUrl="/medical-booking"> -->
<EditForm Model="@Model" OnValidSubmit="HandlerSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="mx-auto min-h-screen max-w-5xl space-y-10 bg-gray-100 p-8">

        <!-- HEADER -->
        <div class="space-y-1">
            <h1 class="text-3xl font-bold text-gray-900">Agendamiento Manual</h1>
            <p class="text-sm text-gray-500">
                Registro de nueva cita médica y servicios terapéuticos
            </p>
        </div>

        <!-- PACIENTE -->
        <div class="space-y-6 rounded-2xl bg-white p-6 shadow-md">

            <h2 class="text-lg font-semibold text-gray-800">
                Datos del Paciente
            </h2>

            <!-- BUSCADOR -->
            <div>
                <label class="text-xs font-semibold uppercase tracking-wide text-gray-500">
                    Buscar paciente
                </label>

                <div class="mt-2 flex gap-3">
                    <InputText @oninput="HandlerInputSearch" @bind-Value="Search"
                               class="w-full rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-sm outline-none transition focus:border-teal-600 focus:bg-white focus:ring-2 focus:ring-teal-500"
                               placeholder="Ej: 10203040 o Juan Perez" />

                    <button type="button"
                            @onclick="HandlerSearch"
                            class="rounded-xl bg-teal-600 px-6 py-3 text-sm font-semibold text-white shadow transition hover:bg-teal-700">
                        Buscar
                    </button>
                </div>
            </div>

            <!-- RESULTADO -->
            <div class="grid gap-4 md:grid-cols-2">

                @if (SearchResult.Any())
                {
                    @foreach (var patient in SearchResult)
                    {
                        var isSelected = SelectedPatient?.PatientIdentification == patient.PatientIdentification;

                        <div class="@GetPatientClass(isSelected)"
                             @onclick="() => SelectPatient(patient)">

                            <p class="text-xs font-semibold uppercase @(isSelected ? "text-teal-700" : "text-gray-600")">
                                Paciente encontrado
                            </p>

                            <p class="mt-1 text-base font-bold @(isSelected ? "text-teal-900" : "text-gray-900")">
                                @patient.PatientName
                            </p>

                            <p class="text-xs @(isSelected ? "text-teal-700" : "text-gray-500")">
                                CC: @patient.PatientIdentification • @patient.PatientPhone
                            </p>
                        </div>
                    }
                }
                else
                {
                    <div class="flex items-center justify-center rounded-xl border border-gray-200 bg-gray-50 p-4 text-sm text-gray-400">
                        No hay paciente seleccionado
                    </div>
                }

                @if (!_isNewPatient)
                {
                    <div @onclick="() => _isNewPatient = true" class="flex min-h-[90px] cursor-pointer items-center justify-center rounded-xl border-2 border-dashed border-gray-300 text-sm text-gray-500 transition hover:border-teal-500 hover:text-teal-600">
                        + Registrar nuevo paciente
                    </div>
                }
                else
                {
                    <div class="col-span-1 space-y-4 rounded-xl border border-teal-100 bg-teal-50 p-5 shadow-sm md:col-span-2">
                        <div class="flex items-center justify-between">
                            <h3 class="font-semibold text-teal-800">Datos del Nuevo Paciente</h3>
                            <button type="button" @onclick="() => _isNewPatient = false" class="text-xs font-semibold text-gray-500 hover:text-red-500">Cancelar</button>
                        </div>
                        <div class="grid gap-4 md:grid-cols-3">
                            <div class="space-y-1">
                                <label class="text-xs font-semibold uppercase tracking-wide text-gray-600">Cédula</label>
                                <InputText @bind-Value="Model.PatientIdentification" class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm outline-none focus:border-teal-500 focus:ring-2 focus:ring-teal-500/50" placeholder="Ej: 10203040" />
                                <ValidationMessage For="@(() => Model.PatientIdentification)" class="text-xs text-red-500" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-xs font-semibold uppercase tracking-wide text-gray-600">Nombres Completos</label>
                                <InputText @bind-Value="Model.PatientName" class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm outline-none focus:border-teal-500 focus:ring-2 focus:ring-teal-500/50" placeholder="Ej: Ana Gómez" />
                                <ValidationMessage For="@(() => Model.PatientName)" class="text-xs text-red-500" />
                            </div>
                            <div class="space-y-1">
                                <label class="text-xs font-semibold uppercase tracking-wide text-gray-600">Teléfono</label>
                                <InputText @bind-Value="Model.PatientPhone" class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm outline-none focus:border-teal-500 focus:ring-2 focus:ring-teal-500/50" placeholder="Ej: 3001234567" />
                                <ValidationMessage For="@(() => Model.PatientPhone)" class="text-xs text-red-500" />
                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>

        <!-- DETALLES -->
        <div class="space-y-6 rounded-2xl bg-white p-6 shadow-md">

            <h2 class="text-lg font-semibold text-gray-800">
                Detalles de la Cita
            </h2>

            <div class="grid gap-6">

                <div class="space-y-4">
                    <MenuTypeMedic OnSelected="HandlerSelectDoctor" OnChange="HandlerChange" />
                </div>

                <div class="space-y-4">
                    @if (Model.Doctor != null)
                    {
                        <AppointmentScheduler DoctorId="@Model.DoctorId"
                                              OnSelected="HandlerSelectAppointmentDate" />
                    }
                    else
                    {
                        <div class="flex h-32 items-center justify-center rounded-xl border border-gray-200 bg-gray-50 text-sm text-gray-400">
                            Selecciona un médico para continuar
                        </div>
                    }
                </div>

            </div>

        </div>

        <!-- ACCIONES -->
        <div class="flex gap-4">

            <button type="submit"
                    class="flex-1 rounded-xl bg-teal-600 py-3 text-sm font-bold tracking-wide text-white shadow-md transition hover:bg-teal-700">
                Guardar agendamiento
            </button>

            <button type="button"
                    @onclick="HandlerCancel"
                    class="rounded-xl border border-gray-300 px-6 py-3 text-sm text-gray-600 transition hover:bg-gray-50">
                Cancelar
            </button>

        </div>

    </div>

</EditForm>
<!-- </AuthorizeGuard> -->
