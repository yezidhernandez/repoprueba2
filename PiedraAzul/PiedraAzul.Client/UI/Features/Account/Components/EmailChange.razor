@using PiedraAzul.Client.Models.GraphQL
@using PiedraAzul.Client.Services.GraphQLServices

<div class="flex flex-col gap-3">
    <div>
        <label class="mb-1.5 block text-xs font-medium text-gray-700">Correo actual</label>
        <input value="@CurrentEmail" readonly
               class="w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-500 cursor-not-allowed" />
    </div>

    @if (!_showVerification)
    {
        <div>
            <label class="mb-1.5 block text-xs font-medium text-gray-700">Nuevo correo</label>
            <div class="flex gap-2 w-full">
                <input type="email"
                       @bind="_newEmail"
                       placeholder="nuevo@email.com"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900
                              transition focus:border-[#2A9D8F] focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/20" />
                <button @onclick="RequestEmailChangeAsync"
                        disabled="@(_loading || string.IsNullOrWhiteSpace(_newEmail) || _newEmail == CurrentEmail)"
                        class="flex-shrink-0 rounded-lg bg-[#2A9D8F] px-4 py-2 text-sm font-semibold text-white
                               transition hover:bg-[#1e7168] disabled:opacity-50">
                    @(_loading ? "..." : "Verificar")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <p class="mt-1 text-xs text-red-500">@_errorMessage</p>
            }
        </div>
    }
    else
    {
        <div class="rounded-lg border border-[#2A9D8F]/30 bg-[#e8f5f3] p-4">
            <p class="mb-3 text-sm font-semibold text-gray-900">Verifica tu nuevo correo</p>
            <p class="mb-3 text-xs text-gray-600">
                Hemos enviado un código de verificación a <strong>@_newEmail</strong>
            </p>

            <div class="mb-3">
                <label class="mb-1.5 block text-xs font-medium text-gray-700">Código de verificación</label>
                <input type="text"
                       @bind="_verificationCode"
                       maxlength="6"
                       placeholder="000000"
                       class="w-full rounded-lg border border-gray-300 px-4 py-2 text-center text-2xl tracking-widest
                              focus:border-[#2A9D8F] focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/20"
                       autocomplete="off" />
            </div>

            <div class="flex gap-2">
                <button @onclick="ConfirmEmailChangeAsync"
                        disabled="@(_verifyingCode || _verificationCode?.Length != 6)"
                        class="flex-1 rounded-lg bg-[#2A9D8F] px-4 py-2 text-sm font-semibold text-white
                               transition hover:bg-[#1e7168] disabled:opacity-50">
                    @(_verifyingCode ? "Confirmando..." : "Confirmar")
                </button>
                <button @onclick="CancelEmailChange"
                        class="flex-1 rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700
                               transition hover:bg-gray-50">
                    Cancelar
                </button>
            </div>

            @if (!string.IsNullOrEmpty(_verificationError))
            {
                <p class="mt-1 text-xs text-red-500">@_verificationError</p>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="rounded-lg border border-[#4CAF7D] bg-[#edf7f2] px-3 py-2 text-xs text-[#166534]">
            @_successMessage
        </div>
    }
</div>

@code {
    private string _newEmail = "";
    private string _verificationCode = "";
    private bool _loading;
    private bool _verifyingCode;
    private bool _showVerification;
    private string? _errorMessage;
    private string? _verificationError;
    private string? _successMessage;

    [Parameter]
    public string CurrentEmail { get; set; } = "";

    [Parameter]
    public GraphQLHttpClient? GraphQL { get; set; }

    [Parameter]
    public EventCallback OnEmailChanged { get; set; }

    private async Task RequestEmailChangeAsync()
    {
        if (string.IsNullOrWhiteSpace(_newEmail) || _newEmail == CurrentEmail)
            return;

        _loading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            const string mutation = """
                mutation RequestEmailChange($input: RequestEmailChangeInput!) {
                    requestEmailChange(input: $input)
                }
                """;

            var result = await GraphQL!.ExecuteAsync<bool>(
                mutation,
                new { input = new { newEmail = _newEmail } },
                "requestEmailChange");

            _showVerification = true;
            _verificationCode = "";
            _verificationError = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmEmailChangeAsync()
    {
        if (string.IsNullOrEmpty(_verificationCode) || _verificationCode.Length != 6)
            return;

        _verifyingCode = true;
        _verificationError = null;
        StateHasChanged();

        try
        {
            const string mutation = """
                mutation ConfirmEmailChange($input: ConfirmEmailChangeInput!) {
                    confirmEmailChange(input: $input)
                }
                """;

            var result = await GraphQL!.ExecuteAsync<bool>(
                mutation,
                new { input = new { newEmail = _newEmail, code = _verificationCode } },
                "confirmEmailChange");

            _successMessage = "Correo actualizado exitosamente.";
            _showVerification = false;
            _newEmail = "";
            _verificationCode = "";

            await OnEmailChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _verificationError = ex.Message;
        }
        finally
        {
            _verifyingCode = false;
            StateHasChanged();
        }
    }

    private void CancelEmailChange()
    {
        _showVerification = false;
        _newEmail = "";
        _verificationCode = "";
        _errorMessage = null;
        _verificationError = null;
        StateHasChanged();
    }
}
