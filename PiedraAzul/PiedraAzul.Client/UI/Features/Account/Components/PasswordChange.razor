@using PiedraAzul.Client.Services.GraphQLServices

<div class="flex flex-col gap-3">
    <div>
        <label class="mb-1.5 block text-xs font-medium text-gray-700">Contraseña actual</label>
        <input type="password" placeholder="••••••••"
               @bind="_current" @bind:event="oninput"
               class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900
                      focus:border-[#2A9D8F] focus:outline-none focus:ring-2 focus:ring-[#2A9D8F]/20 transition" />
    </div>

    <div>
        <label class="mb-1.5 block text-xs font-medium text-gray-700">Nueva contraseña</label>
        <input type="password" placeholder="••••••••"
               @bind="_next" @bind:event="oninput"
               class="w-full rounded-lg border @(_next.Length > 0 && _next.Length < 8 ? "border-yellow-400" : "border-gray-300")
                      px-3 py-2 text-sm text-gray-900 focus:border-[#2A9D8F] focus:outline-none
                      focus:ring-2 focus:ring-[#2A9D8F]/20 transition" />
        @if (_next.Length > 0 && _next.Length < 8)
        {
            <p class="mt-1 text-xs text-yellow-600">Mínimo 8 caracteres</p>
        }
    </div>

    <div>
        <label class="mb-1.5 block text-xs font-medium text-gray-700">Confirmar nueva contraseña</label>
        <div class="relative">
            <input type="password" placeholder="••••••••"
                   @bind="_confirm" @bind:event="oninput"
                   class="w-full rounded-lg border @(Mismatch ? "border-[#E76F51]" : Match ? "border-[#4CAF7D]" : "border-gray-300")
                          px-3 py-2 pr-9 text-sm text-gray-900 focus:border-[#2A9D8F] focus:outline-none
                          focus:ring-2 focus:ring-[#2A9D8F]/20 transition" />
            @if (Match)
            {
                <svg class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-[#4CAF7D]"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <polyline points="20 6 9 17 4 12" />
                </svg>
            }
            else if (Mismatch)
            {
                <svg class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-[#E76F51]"
                     fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
                </svg>
            }
        </div>
        @if (Mismatch)
        {
            <p class="mt-1 text-xs text-[#E76F51]">Las contraseñas no coinciden</p>
        }
        else if (Match)
        {
            <p class="mt-1 text-xs text-[#4CAF7D]">Las contraseñas coinciden ✓</p>
        }
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="rounded-lg bg-orange-50 border border-orange-200 px-3 py-2 text-xs text-[#E76F51]">@_error</div>
    }
    @if (_saved)
    {
        <div class="rounded-lg bg-[#edf7f2] border border-[#4CAF7D] px-3 py-2 text-xs text-[#166534]">
            ✓ Contraseña actualizada correctamente.
        </div>
    }

    <div class="flex justify-end pt-1">
        <button @onclick="HandleSubmit" disabled="@_loading"
                class="rounded-lg bg-[#2A9D8F] px-4 py-2 text-sm font-semibold text-white
                       transition hover:bg-[#1e7168] disabled:opacity-50">
            @(_loading ? "Actualizando..." : "Actualizar contraseña")
        </button>
    </div>
</div>

@code {
    [Parameter] public GraphQLHttpClient? GraphQL { get; set; }

    private string _current = "";
    private string _next = "";
    private string _confirm = "";
    private bool _loading;
    private bool _saved;
    private string? _error;

    private bool Match => _next.Length > 0 && _confirm.Length > 0 && _next == _confirm;
    private bool Mismatch => _next.Length > 0 && _confirm.Length > 0 && _next != _confirm;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_current) || string.IsNullOrWhiteSpace(_next) || string.IsNullOrWhiteSpace(_confirm))
        {
            _error = "Completa todos los campos.";
            return;
        }
        if (_next.Length < 8) { _error = "La nueva contraseña debe tener al menos 8 caracteres."; return; }
        if (_next != _confirm) { _error = "Las contraseñas no coinciden."; return; }

        _loading = true;
        _error = null;
        _saved = false;
        StateHasChanged();

        try
        {
            const string mutation = """
                mutation ChangePassword($input: ChangePasswordInput!) {
                    changePassword(input: $input)
                }
                """;

            var result = await GraphQL!.ExecuteAsync<bool>(
                mutation,
                new { input = new { currentPassword = _current, newPassword = _next } },
                "changePassword");

            if (result)
            {
                _saved = true;
                _current = _next = _confirm = "";
                await Task.Delay(3000);
                _saved = false;
                StateHasChanged();
            }
            else
            {
                _error = "No se pudo actualizar. Verifica tu contraseña actual.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
