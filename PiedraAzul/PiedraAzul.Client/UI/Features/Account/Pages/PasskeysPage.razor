@page "/account/passkeys"
@using PiedraAzul.Client.Services.AuthServices
@using PiedraAzul.Client.States
@using PiedraAzul.Client.UI.Shared.Components
@inject PasskeyService PasskeyService
@inject UserState UserState
@inject NavigationManager Nav
@inject IJSRuntime JS
<AuthorizeGuard RequiredRole="Patient">

<PageTitle>Mis Passkeys | Piedra Azul</PageTitle>

<div class="mx-auto max-w-lg px-4 py-10">
    <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-xl md:p-8">

        <h2 class="text-2xl font-bold text-gray-800">Mis Passkeys</h2>
        <p class="mt-2 text-sm text-gray-500">
            Registra tu cara, huella o llave de seguridad para entrar sin contraseña.
        </p>

        @if (!_supported)
        {
            <div class="mt-6 rounded-lg bg-yellow-50 border border-yellow-200 p-4 text-sm text-yellow-800">
                Tu navegador no soporta passkeys. Prueba con Chrome, Safari o Edge actualizados.
            </div>
        }
        else
        {
            <div class="mt-6 space-y-4">
                <div>
                    <label class="mb-1 block text-sm font-semibold text-gray-700">
                        Nombre para esta passkey
                    </label>
                    <input @bind="_friendlyName"
                           type="text"
                           placeholder="Ej: Face ID iPhone, Windows Hello, YubiKey"
                           class="w-full rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-700
                                  focus:border-teal-400 focus:outline-none focus:ring-2 focus:ring-teal-400" />
                </div>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <p class="text-sm text-red-500">@_error</p>
                }

                @if (_success)
                {
                    <div class="rounded-lg bg-green-50 border border-green-200 p-4 text-sm text-green-800">
                        Passkey registrada correctamente. Ya puedes usarla para ingresar.
                    </div>
                }

                <button @onclick="RegisterPasskeyAsync"
                        disabled="@_loading"
                        class="w-full rounded-lg bg-[#257D8D] py-3 font-semibold text-white shadow-md
                               transition duration-200 hover:bg-[#1E5F6F] disabled:opacity-60">
                    @(_loading ? "Registrando..." : "Registrar passkey")
                </button>

                <button @onclick='() => Nav.NavigateTo("/")'
                        class="w-full rounded-lg bg-gray-100 py-3 font-semibold text-gray-700
                               transition duration-200 hover:bg-gray-200">
                    Volver
                </button>
            </div>
        }
    </div>
</div>

</AuthorizeGuard>
@code {
    private bool _supported = true;
    private bool _loading;
    private bool _success;
    private string? _error;
    private string _friendlyName = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _supported = await PasskeyService.IsSupportedAsync();
        StateHasChanged();
    }

    private async Task RegisterPasskeyAsync()
    {
        if (UserState.User is null)
        {
            Nav.NavigateTo("/account/auth");
            return;
        }

        _loading = true;
        _error = null;
        _success = false;
        StateHasChanged();

        try
        {
            await JS.InvokeVoidAsync("console.log", "1. Iniciando registro de passkey");

            var result = await PasskeyService.RegisterAsync(
                UserState.User.Id,
                UserState.User.Email,
                UserState.User.Name,
                string.IsNullOrWhiteSpace(_friendlyName) ? "Mi passkey" : _friendlyName);

            await JS.InvokeVoidAsync("console.log", "2. Resultado:", result.IsSuccess, result.Error?.Message);

            if (result.IsSuccess)
            {
                _success = true;
            }
            else
            {
                _error = result.Error?.Message ?? "No se pudo registrar la passkey. Inténtalo de nuevo.";
            }
        }
        catch (Exception ex) when (ex.Message.Contains("cancel", StringComparison.OrdinalIgnoreCase)
                                   || ex.Message.Contains("abort", StringComparison.OrdinalIgnoreCase))
        {
            _error = "Cancelaste el registro.";
            await JS.InvokeVoidAsync("console.log", "Cancelado:", ex.Message);
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
            await JS.InvokeVoidAsync("console.error", "Exception:", ex.Message, ex.StackTrace);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
