@using PiedraAzul.Client.Models.Schedule
@page "/doctor/configurar-horario"
@layout PiedraAzul.Client.UI.Shared.Layout.EmptyLayout
@using System.Globalization
@using PiedraAzul.Client.States
@inject UserState UserState
@inject IJSRuntime JS

<div class="min-h-screen bg-slate-50 pb-12">
    
    <!-- HEADER / NAV -->
    <header class="bg-white border-b sticky top-0 z-30">
        <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <!-- Logo -->
                <div class="flex items-center gap-3">
                    <div class="bg-primary p-2 rounded-lg text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                    </div>
                    <span class="text-xl font-bold text-slate-800">Piedra Azul</span>
                </div>

                <!-- Nav Links -->
                <nav class="hidden md:flex items-center gap-8">
                    <a href="/doctor" class="text-slate-500 font-medium hover:text-slate-900 transition-colors">Dashboard</a>
                    <a href="/doctor/pacientes" class="text-slate-500 font-medium hover:text-slate-900 transition-colors">Pacientes</a>
                    <a href="/doctor/agenda" class="text-slate-900 font-semibold border-b-2 border-primary py-7">Mi Agenda</a>
                </nav>
            </div>

            <div class="flex items-center gap-6">
                <!-- User Profile -->
                <div class="flex items-center gap-3 pl-6 border-l">
                    <div class="text-right hidden sm:block">
                        <div class="text-sm font-bold text-slate-900">Dr. Roberto Gómez</div>
                        <div class="text-xs text-slate-400">Doctor</div>
                    </div>
                    <img src="https://ui-avatars.com/api/?name=Roberto+Gomez&background=257D8D&color=fff" alt="Doctor" class="w-10 h-10 rounded-full border-2 border-slate-100 shadow-sm" />
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 mt-8">
        <!-- Breadcrumbs -->
        <nav class="flex text-sm text-slate-400 mb-6 font-medium" aria-label="Breadcrumb">
            <ol class="flex items-center space-x-2">
                <li><a href="/doctor/agenda" class="hover:text-primary transition-colors">Mi agenda</a></li>
                <li class="flex items-center space-x-2">
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
                    <span class="text-slate-600">Horario</span>
                </li>
            </ol>
        </nav>

        <!-- Header Title & Controls -->
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 mb-10">
            <div class="flex items-center gap-6">
                <button @onclick="GoBack" class="p-4 bg-white border border-slate-200 rounded-2xl text-slate-400 hover:text-primary transition-all shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </button>
                <div>
                    <h1 class="text-5xl font-black text-slate-900 mb-2">Configurar Horario</h1>
                    <p class="text-slate-500 text-lg font-medium">Gestiona tu disponibilidad semanal para citas con pacientes.</p>
                </div>
            </div>
            
            <div class="flex items-center gap-4 bg-white p-1.5 rounded-2xl shadow-sm border border-slate-100">
                <a href="/doctor/agenda" class="text-slate-500 px-6 py-3 rounded-xl font-bold hover:bg-slate-50 transition-all">
                    Calendario
                </a>
                <a href="/doctor/configurar-horario" class="bg-primary text-white px-6 py-3 rounded-xl font-bold shadow-lg shadow-primary/20 transition-all">
                    Configurar Horario
                </a>
            </div>
        </div>

        <div class="mt-12 grid grid-cols-1 lg:grid-cols-[300px_1fr] gap-10">
            
            <!-- Sidebar -->
            <aside class="space-y-8">
                <!-- Mini Calendar Card -->
                <div class="bg-white rounded-[2rem] p-8 shadow-sm border border-slate-100">
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="font-black text-slate-900 text-xl">Marzo 2026</h3>
                        <div class="text-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        </div>
                    </div>
                    <div class="grid grid-cols-5 text-center text-[10px] font-black text-slate-400 uppercase tracking-tighter mb-6">
                        <span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span>
                    </div>
                    <div class="grid grid-cols-5 text-center gap-y-3">
                        @for (int i = 1; i <= 31; i++)
                        {
                            var date = new DateTime(2026, 3, i);
                            if (date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday) continue;

                            var isSelectedWeek = i >= 9 && i <= 13;
                            <div class="py-1 text-sm font-black @(isSelectedWeek ? "bg-primary text-white rounded-full w-8 h-8 flex items-center justify-center mx-auto shadow-lg shadow-primary/30" : "text-slate-400")">
                                @i
                            </div>
                        }
                    </div>
                </div>

                <!-- Status Legend -->
                <div class="bg-white rounded-[2rem] p-8 shadow-sm border border-slate-100">
                    <h3 class="font-black text-slate-900 mb-6">Estado</h3>
                    <div class="space-y-5">
                        <div class="flex items-center gap-3">
                            <div class="w-5 h-5 rounded-lg bg-primary"></div>
                            <span class="text-sm font-bold text-slate-600">Disponible</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-5 h-5 rounded-lg bg-slate-200"></div>
                            <span class="text-sm font-bold text-slate-600">Bloqueado</span>
                        </div>
                    </div>
                    <div class="mt-8 pt-8 border-t border-slate-50">
                        <div class="flex gap-4 text-slate-400">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                            <p class="text-xs font-bold leading-relaxed">Haz clic en cualquier franja horaria de @Intervalo min para cambiar su disponibilidad.</p>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Main Content -->
            <div class="space-y-8">
                <!-- Interval Selection Card -->
                <div class="bg-white rounded-[2.5rem] p-10 shadow-sm border border-slate-100 flex flex-col md:flex-row items-center justify-between gap-8">
                    <div>
                        <h2 class="text-4xl font-black text-slate-900 mb-3">Configuración de intervalo de atención</h2>
                        <p class="text-slate-500 font-medium">Ajusta la configuración detallada del cronograma para la semana seleccionada.</p>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-3xl border border-slate-100 flex items-center gap-4 min-w-[280px]">
                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-2 whitespace-nowrap">Intervalo de atención</span>
                        <select @bind="Intervalo" class="flex-1 bg-white border border-slate-200 rounded-xl px-4 py-2 font-black text-slate-700 focus:outline-none focus:ring-4 focus:ring-primary/10 transition-all">
                            <option value="5">5 min</option>
                            <option value="10">10 min</option>
                            <option value="15">15 min</option>
                            <option value="20">20 min</option>
                        </select>
                    </div>
                </div>

                <!-- Schedule Grid -->
                <div class="bg-white rounded-[2.5rem] shadow-xl shadow-slate-200/40 border border-slate-100 overflow-hidden">
                    <div class="grid grid-cols-[120px_1fr_1fr_1fr_1fr_1fr] border-b border-slate-100 bg-slate-50/20">
                        <div class="p-8 flex items-center justify-center text-[10px] font-black text-slate-400 uppercase tracking-widest border-r border-slate-100">Horario</div>
                        @foreach (var day in WeekDays)
                        {
                            <div class="p-8 border-r border-slate-100 last:border-0 text-center relative group @(day.IsBlocked ? "bg-slate-50/50" : "")">
                                <button @onclick="() => ToggleDay(day)" class="block w-full text-center hover:opacity-70 transition-all">
                                    <div class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">@day.DayName</div>
                                    <div class="text-3xl font-black text-slate-900 mb-4">@day.DayNumber</div>
                                </button>
                                <div class="flex justify-center">
                                    <label class="relative inline-flex items-center cursor-pointer group">
                                        <input type="checkbox" checked="@(!day.IsBlocked)" @onchange="() => ToggleDay(day)" class="sr-only peer">
                                        <div class="w-12 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
                                    </label>
                                </div>
                                @if (!day.IsBlocked)
                                {
                                    <div class="absolute inset-x-0 bottom-0 h-1.5 bg-primary"></div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Grid Rows -->
                    <div class="divide-y divide-slate-100">
                        @foreach (var hour in Hours)
                        {
                            <div class="grid grid-cols-[120px_1fr_1fr_1fr_1fr_1fr]">
                                <div class="p-8 flex items-start justify-center font-black text-slate-900 text-xl border-r border-slate-100">@hour:00 AM</div>
                                @foreach (var day in WeekDays)
                                {
                                    <div class="p-6 border-r border-slate-100 last:border-0 @(day.IsBlocked ? "bg-slate-50/50 flex items-center justify-center italic text-slate-400 font-bold text-sm" : "")">
                                        @if (day.IsBlocked)
                                        {
                                            <span>Bloqueado</span>
                                        }
                                        else
                                        {
                                            <div class="grid grid-cols-1 gap-3">
                                                @foreach (var slot in GetSlotsForHour(day, hour))
                                                {
                                                    <button @onclick="() => slot.IsActive = !slot.IsActive"
                                                            class="w-full py-3.5 px-6 rounded-2xl text-[11px] font-black transition-all border flex items-center justify-between group
                                                                   @(slot.IsActive ? "bg-primary text-white border-primary shadow-xl shadow-primary/20" : "bg-white text-slate-300 border-slate-100 hover:border-slate-300")">
                                                        <span>@slot.StartTime</span>
                                                        @if (!slot.IsActive)
                                                        {
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="opacity-50"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                                                        }
                                                    </button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        
                        <!-- Lunch Break / Bottom padding -->
                        <div class="grid grid-cols-[120px_1fr_1fr_1fr_1fr_1fr] bg-emerald-50/10">
                             <div class="p-8 flex items-start justify-center font-black text-slate-900 text-xl border-r border-slate-100">12:00 PM</div>
                             @foreach (var day in WeekDays)
                             {
                                 <div class="p-6 border-r border-slate-100 last:border-0 flex items-center justify-center">
                                     <div class="w-full h-14 bg-primary/10 rounded-[1.5rem] border border-primary/5"></div>
                                 </div>
                             }
                        </div>
                    </div>
                </div>

                <!-- Footer Actions -->
                <div class="flex items-center justify-end gap-6 pt-10">
                    <a href="/servicios/exportar-citas" class="bg-white border-2 border-slate-100 px-12 py-5 rounded-[2rem] font-black text-slate-600 hover:bg-slate-50 transition-all uppercase tracking-widest text-xs">
                        Exportar datos
                    </a>
                    <button class="flex items-center gap-4 bg-primary text-white px-16 py-5 rounded-[2rem] font-black text-sm hover:opacity-90 transition-all shadow-2xl shadow-primary/40">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        GUARDAR
                    </button>
                </div>
            </div>
        </div>
    </main>
</div>

@code {
    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private int Intervalo { get; set; } = 10;
    private List<DayScheduleModel> WeekDays = new();
    private List<int> Hours = new() { 9, 10, 11 };

    protected override void OnInitialized()
    {
        InitializeSchedule();
    }

    private void InitializeSchedule()
    {
        WeekDays = new List<DayScheduleModel>
        {
            new() { DayName = "Lun", DayNumber = 9 },
            new() { DayName = "Mar", DayNumber = 10 },
            new() { DayName = "Mier", DayNumber = 11, IsBlocked = true },
            new() { DayName = "Jue", DayNumber = 12 },
            new() { DayName = "Vie", DayNumber = 13 }
        };

        foreach (var day in WeekDays)
        {
            GenerateSlotsForDay(day);
        }
    }

    private void GenerateSlotsForDay(DayScheduleModel day)
    {
        day.Slots.Clear();
        foreach (var hour in Hours)
        {
            for (int min = 0; min < 60; min += Intervalo)
            {
                var time = DateTime.Today.AddHours(hour).AddMinutes(min);
                day.Slots.Add(new TimeSlotModel { StartTime = $"{time:HH:mm}", IsActive = true });
            }
        }
        
        // Mock some inactive slots as in prototype
        if (day.DayName == "Lun") {
            day.Slots[2].IsActive = false;
            day.Slots[3].IsActive = false;
        }
        if (day.DayName == "Jue") {
            day.Slots[1].IsActive = false;
            day.Slots[5].IsActive = false;
            day.Slots[7].IsActive = false;
            day.Slots[11].IsActive = false;
            day.Slots[17].IsActive = false;
        }
        if (day.DayName == "Vie") {
            day.Slots[3].IsActive = false;
            day.Slots[4].IsActive = false;
            day.Slots[5].IsActive = false;
            day.Slots[10].IsActive = false;
            day.Slots[11].IsActive = false;
            day.Slots[15].IsActive = false;
            day.Slots[16].IsActive = false;
            day.Slots[17].IsActive = false;
        }
    }

    private IEnumerable<TimeSlotModel> GetSlotsForHour(DayScheduleModel day, int hour)
    {
        return day.Slots.Where(s => int.TryParse(s.StartTime[..2], out var slotHour) && slotHour == hour);
    }

    private void ToggleDay(DayScheduleModel day)
    {
        day.IsBlocked = !day.IsBlocked;
    }

}

<style>
    .bg-primary { background-color: #257D8D; }
    .text-primary { color: #257D8D; }
    .border-primary { border-color: #257D8D; }
    .shadow-primary\/20 { --tw-shadow-color: rgba(37, 125, 141, 0.2); }
    .shadow-primary\/30 { --tw-shadow-color: rgba(37, 125, 141, 0.3); }
    .shadow-primary\/40 { --tw-shadow-color: rgba(37, 125, 141, 0.4); }
</style>
