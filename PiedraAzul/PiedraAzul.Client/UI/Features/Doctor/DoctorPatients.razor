@page "/doctor/pacientes"
@layout PiedraAzul.Client.UI.Shared.Layout.EmptyLayout
@using PiedraAzul.Client.Models.GraphQL
@using PiedraAzul.Client.States
@inject UserState UserState
@inject PiedraAzul.Client.Services.GraphQLServices.GraphQLPatientService PatientService
@inject IJSRuntime JS

<div class="min-h-screen bg-slate-50 pb-12">
    
    <!-- HEADER / NAV (Reusable from DoctorPanel) -->
    <header class="bg-white border-b sticky top-0 z-30">
        <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <!-- Logo -->
                <div class="flex items-center gap-3">
                    <div class="bg-primary p-2 rounded-lg text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                    </div>
                    <span class="text-xl font-bold text-slate-800">Piedra Azul</span>
                </div>

                <!-- Nav Links -->
                <nav class="hidden md:flex items-center gap-8">
                    <a href="/doctor" class="text-slate-500 font-medium hover:text-slate-900 transition-colors py-7">Dashboard</a>
                    <a href="/doctor/pacientes" class="text-slate-900 font-semibold border-b-2 border-primary py-7">Pacientes</a>
                    <a href="/doctor/agenda" class="text-slate-500 font-medium hover:text-slate-900 transition-colors">Mi Agenda</a>
                </nav>
            </div>

            <div class="flex items-center gap-6">
                <button class="relative p-2 text-slate-400 hover:text-slate-600 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                </button>

                <!-- User Profile -->
                <div class="flex items-center gap-3 pl-6 border-l">
                    <div class="text-right hidden sm:block">
                        <div class="text-sm font-bold text-slate-900">Dr. Roberto Gómez</div>
                        <div class="text-xs text-slate-400">Doctor</div>
                    </div>
                    <img src="https://ui-avatars.com/api/?name=Roberto+Gomez&background=257D8D&color=fff" alt="Doctor" class="w-10 h-10 rounded-full border-2 border-slate-100 shadow-sm" />
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 mt-12">
        
        <!-- Page Title -->
        <div class="mb-10 flex items-center gap-6">
            <button @onclick="GoBack" class="p-4 bg-white border border-slate-200 rounded-2xl text-slate-400 hover:text-primary transition-all shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <div>
                <h1 class="text-5xl font-black text-slate-900 mb-2">Base de datos del paciente</h1>
                <p class="text-slate-500 text-xl font-medium">Maneja y mira registros de todos los pacientes registrados.</p>
            </div>
        </div>

        <!-- Filters Section -->
        <div class="bg-white rounded-[2rem] p-8 shadow-sm border border-slate-100 flex flex-col md:flex-row items-end gap-6 mb-10">
            <div class="flex-1 w-full">
                <label class="block text-slate-500 font-bold uppercase tracking-wider text-xs mb-3 ml-1">ESPECIALISTA</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-5 flex items-center pointer-events-none text-slate-400 group-focus-within:text-primary transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    </div>
                    <input type="text" 
                           placeholder="Busca pacientes por nombre, id, teléfono..." 
                           class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-4 pl-14 pr-6 focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all" />
                </div>
            </div>

            <div class="w-full md:w-72">
                <label class="block text-slate-500 font-bold uppercase tracking-wider text-xs mb-3 ml-1">FECHA</label>
                <div class="relative group">
                    <input type="date" 
                           class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-4 px-6 focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all text-slate-700 font-medium" />
                </div>
            </div>

            <button class="bg-primary text-white px-10 py-4 rounded-2xl font-bold hover:opacity-90 transition-all shadow-lg shadow-primary/20 h-[60px]">
                Buscar
            </button>
        </div>

        <!-- Patients Table -->
        <div class="bg-white rounded-[2rem] shadow-sm border border-slate-100 overflow-hidden mb-8">
            <div class="overflow-x-auto">
                <table class="w-full border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-100">
                            <th class="px-8 py-6 text-left text-slate-400 font-bold uppercase tracking-[0.1em] text-[11px]">NOMBRE PACIENTE</th>
                            <th class="px-8 py-6 text-left text-slate-400 font-bold uppercase tracking-[0.1em] text-[11px]">IDENTIFICACIÓN</th>
                            <th class="px-8 py-6 text-left text-slate-400 font-bold uppercase tracking-[0.1em] text-[11px]">ULTIMA VISITA</th>
                            <th class="px-8 py-6 text-left text-slate-400 font-bold uppercase tracking-[0.1em] text-[11px]">ESTADO</th>
                            <th class="px-8 py-6 text-right text-slate-400 font-bold uppercase tracking-[0.1em] text-[11px]">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @foreach (var p in dummyPatients)
                        {
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-8 py-6">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center font-bold text-xs">
                                            @GetInitials(p.Name)
                                        </div>
                                        <span class="font-bold text-slate-900 text-lg">@p.Name</span>
                                    </div>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="text-slate-600 font-bold font-mono">@p.Id</span>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="text-slate-500 font-medium">@p.LastVisit</span>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl text-xs font-bold @GetStatusClass(p.Status)">
                                        <span class="w-1.5 h-1.5 rounded-full @GetStatusDotClass(p.Status)"></span>
                                        @p.Status
                                    </span>
                                </td>
                                <td class="px-8 py-6 text-right">
                                    <div class="flex items-center justify-end gap-3">
                                        <button class="flex items-center gap-2 bg-slate-50 text-slate-600 px-4 py-2 rounded-xl text-sm font-bold hover:bg-slate-100 transition-all">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
                                            Ver registros
                                        </button>
                                        <button class="flex items-center gap-2 bg-primary/10 text-primary px-4 py-2 rounded-xl text-sm font-bold hover:bg-primary/20 transition-all border border-primary/20">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
                                            Cita nueva
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Table Footer / Pagination -->
            <div class="bg-slate-50/50 px-8 py-6 flex items-center justify-between">
                <span class="text-slate-500 font-medium">Mostrando 1 a 4 de 248 pacientes</span>
                
                <div class="flex items-center gap-2">
                    <button class="p-2 text-slate-400 hover:text-slate-900 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                    </button>
                    <button class="w-10 h-10 rounded-full bg-primary text-white font-bold flex items-center justify-center shadow-lg shadow-primary/30">1</button>
                    <button class="w-10 h-10 rounded-full text-slate-500 font-bold flex items-center justify-center hover:bg-slate-100 transition-colors">2</button>
                    <button class="w-10 h-10 rounded-full text-slate-500 font-bold flex items-center justify-center hover:bg-slate-100 transition-colors">3</button>
                    <span class="text-slate-400 px-2">...</span>
                    <button class="w-10 h-10 rounded-full text-slate-500 font-bold flex items-center justify-center hover:bg-slate-100 transition-colors">62</button>
                    <button class="p-2 text-slate-400 hover:text-slate-900 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Bottom Actions -->
        <div class="flex justify-end">
            <a href="/servicios/exportar-citas" class="bg-primary text-white px-8 py-4 rounded-2xl font-bold flex items-center gap-3 hover:opacity-90 transition-all shadow-lg shadow-primary/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Exportar datos
            </a>
        </div>
        

        <footer class="mt-20 flex flex-col md:flex-row items-center justify-between gap-6 py-8 border-t border-slate-100">
            <div class="text-slate-400 font-medium italic text-sm">
                © 2026 Clínica Piedra Azul.
            </div>
            <div class="flex items-center gap-8 text-sm font-bold text-slate-500">
                <a href="#" class="hover:text-primary transition-colors">Política de Privacidad</a>
                <a href="#" class="hover:text-primary transition-colors">Términos y condiciones</a>
                <a href="#" class="hover:text-primary transition-colors">Soporte</a>
            </div>
        </footer>

    </main>
</div>

@code {
    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    private class PatientVM
    {
        public string Name { get; set; } = "";
        public string Id { get; set; } = "";
        public string LastVisit { get; set; } = "";
        public string Status { get; set; } = "";
    }

    private List<PatientVM> dummyPatients = new()
    {
        new() { Name = "Juan Díaz", Id = "1002964507", LastVisit = "15 mar, 2026", Status = "Activo" },
        new() { Name = "Mango Güeno", Id = "1001234567", LastVisit = "15 mar, 2026", Status = "Programado" },
        new() { Name = "Rafael Sánchez", Id = "1007654321", LastVisit = "14 mar, 2026", Status = "Inactivo" },
        new() { Name = "Alice Wonderful", Id = "1001324567", LastVisit = "10 dic, 1996", Status = "Activo" }
    };

    private string GetInitials(string name)
    {
        var parts = name.Split(' ');
        return string.Join("", parts.Select(p => p[0])).ToUpper();
    }

    private string GetStatusClass(string status) => status switch
    {
        "Activo" => "bg-emerald-50 text-emerald-600",
        "Programado" => "bg-amber-50 text-amber-600",
        "Inactivo" => "bg-slate-100 text-slate-500",
        _ => "bg-slate-50 text-slate-400"
    };

    private string GetStatusDotClass(string status) => status switch
    {
        "Activo" => "bg-emerald-500",
        "Programado" => "bg-amber-500",
        "Inactivo" => "bg-slate-400",
        _ => "bg-slate-300"
    };
}
