@page "/doctor"
@layout PiedraAzul.Client.UI.Shared.Layout.EmptyLayout
@using PiedraAzul.Client.States
@inject UserState UserState

<div class="min-h-screen bg-slate-50 pb-12">
   <!-- HEADER / NAV -->
    <header class="bg-white border-b sticky top-0 z-30">
        <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <!-- Logo -->
                <div class="flex items-center gap-3">
                    <div class="bg-primary p-2 rounded-lg text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                    </div>
                    <span class="text-xl font-bold text-slate-800">Piedra Azul</span>
                </div>

                <!-- Nav Links -->
                <nav class="hidden md:flex items-center gap-8">
                    <a href="/doctor" class="text-slate-900 font-semibold border-b-2 border-primary py-7">Dashboard</a>
                    <a href="/doctor/pacientes" class="text-slate-500 font-medium hover:text-slate-900 transition-colors">Pacientes</a>
                    <a href="/doctor/agenda" class="text-slate-500 font-medium hover:text-slate-900 transition-colors">Mi Agenda</a>
                </nav>
            </div>

            <div class="flex items-center gap-6">
                <!-- Notifications -->
                <button class="relative p-2 text-slate-400 hover:text-slate-600 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-rose-500 rounded-full border-2 border-white"></span>
                </button>

                <!-- User Profile -->
                <div class="flex items-center gap-3 pl-6 border-l">
                    <div class="text-right hidden sm:block">
                        <div class="text-sm font-bold text-slate-900">Dr. Roberto Gómez</div>
                        <div class="text-xs text-slate-400">Doctor</div>
                    </div>
                    <img src="/Avatars/doctor-avatar.png" alt="Doctor" class="w-10 h-10 rounded-full border-2 border-slate-100 shadow-sm" onerror="this.src='https://ui-avatars.com/api/?name=Roberto+Gomez&background=257D8D&color=fff'" />
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 mt-8">
        <!-- Profile Card -->
        <div class="bg-white rounded-3xl p-8 shadow-sm border border-slate-100 flex flex-col md:flex-row items-center justify-between gap-6 mb-8">
            <div class="flex flex-col md:flex-row items-center gap-8">
                <div class="relative">
                    <img src="/Avatars/doctor-avatar.png" alt="Profile" class="w-32 h-32 rounded-full border-4 border-slate-50 shadow-md object-cover" onerror="this.src='https://ui-avatars.com/api/?name=Roberto+Gomez&background=257D8D&color=fff'" />
                    <div class="absolute bottom-2 right-2 w-5 h-5 bg-emerald-500 border-4 border-white rounded-full"></div>
                </div>
                <div class="text-center md:text-left">
                    <h1 class="text-4xl font-bold text-slate-900 mb-3">Dr. Roberto Gómez</h1>
                    <div class="flex flex-wrap items-center gap-3 justify-center md:justify-start">
                        <span class="bg-primary/10 text-primary px-4 py-1.5 rounded-xl text-sm font-semibold">Especialista en Dieta y Nutrición</span>
                        <span class="bg-emerald-50/80 text-emerald-600 px-4 py-1.5 rounded-xl text-sm font-semibold flex items-center gap-2">
                            <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
                            Estado: Activo
                        </span>
                    </div>
                </div>
            </div>
            
            <button class="bg-primary text-white px-8 py-3.5 rounded-2xl font-bold flex items-center gap-3 hover:opacity-90 transition-all shadow-lg shadow-primary/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                Estado
            </button>
        </div>

        <!-- Search Bar -->
        <div class="relative mb-12 group">
            <div class="absolute inset-y-0 left-6 flex items-center pointer-events-none text-slate-400 group-focus-within:text-primary transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <input type="text" 
                   placeholder="Buscar historia médica (Nombre, identificación, o teléfono...)" 
                   class="w-full bg-white border border-slate-200 rounded-2xl py-5 pl-16 pr-8 text-lg focus:outline-none focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all shadow-sm" />
        </div>

        <!-- Stats Section -->
        <div class="mb-12">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-2xl font-bold text-slate-900">Resumen citas de hoy</h2>
                <span class="text-slate-500 font-medium">@DateTime.Now.ToString("dd MMMM, yyyy", new System.Globalization.CultureInfo("es-ES"))</span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Total Citas -->
                <div class="bg-white rounded-3xl p-8 border-l-[6px] border-primary shadow-sm hover:shadow-md transition-all">
                    <div class="flex items-start justify-between mb-4">
                        <span class="text-slate-500 font-bold uppercase tracking-wider text-sm">TOTAL CITAS</span>
                        <div class="p-2 bg-slate-50 rounded-lg text-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        </div>
                    </div>
                    <div class="text-6xl font-black text-slate-900 mb-4">12</div>
                    <div class="text-primary font-semibold flex items-center gap-2">
                        4 llegadas confirmadas
                    </div>
                </div>

                <!-- Completadas -->
                <div class="bg-white rounded-3xl p-8 border-l-[6px] border-emerald-500 shadow-sm hover:shadow-md transition-all">
                    <div class="flex items-start justify-between mb-4">
                        <span class="text-slate-500 font-bold uppercase tracking-wider text-sm">COMPLETADAS</span>
                        <div class="p-2 bg-slate-50 rounded-lg text-emerald-500">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        </div>
                    </div>
                    <div class="text-6xl font-black text-slate-900 mb-4">4</div>
                    <div class="text-emerald-500 font-semibold flex items-center gap-2">
                        33% de la meta diaria
                    </div>
                </div>

                <!-- Pendientes -->
                <div class="bg-white rounded-3xl p-8 border-l-[6px] border-amber-500 shadow-sm hover:shadow-md transition-all">
                    <div class="flex items-start justify-between mb-4">
                        <span class="text-slate-500 font-bold uppercase tracking-wider text-sm">PENDIENTES</span>
                        <div class="p-2 bg-slate-50 rounded-lg text-amber-500">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><circle cx="12" cy="14" r="3"/><path d="M12 11v3h2"/></svg>
                        </div>
                    </div>
                    <div class="text-6xl font-black text-slate-900 mb-4">8</div>
                    <div class="text-amber-600 font-semibold flex items-center gap-2">
                        Siguiente: 10:30 AM
                    </div>
                </div>
            </div>
        
        <!-- Action Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-20">
            <!-- Mirar la agenda -->
            <a href="/doctor/agenda" class="bg-primary rounded-[2.5rem] p-10 flex items-center justify-between group overflow-hidden relative shadow-2xl shadow-primary/30 hover:-translate-y-1 transition-all">
                <div class="relative z-10">
                    <h3 class="text-3xl font-black text-white mb-2">Mirar la agenda</h3>
                    <p class="text-white/70 text-lg">Maneja tu tiempo y vainas más</p>
                </div>
                <div class="relative z-10 text-white transform group-hover:translate-x-2 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </div>
                <!-- Subtle background flourish -->
                <div class="absolute -right-8 -bottom-8 w-48 h-48 bg-white/10 rounded-full blur-3xl"></div>
            </a>

            <!-- Registros pacientes -->
            <a href="/doctor/pacientes" class="bg-white border-2 border-primary/20 rounded-[2.5rem] p-10 flex items-center justify-between group hover:border-primary hover:shadow-xl transition-all">
                <div>
                    <h3 class="text-3xl font-black text-primary mb-2">Registros pacientes</h3>
                    <p class="text-slate-400 text-lg">Accede a los registros</p>
                </div>
                <div class="text-primary opacity-50 group-hover:opacity-100 transition-opacity">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M8 13h2"/><path d="M8 17h2"/><path d="M14 13h2"/><path d="M14 17h2"/></svg>
                </div>
            </a>
        </div>

        <footer class="mt-20 text-center text-slate-400 font-medium">
            © 2026 Clínica Piedra Azul.
        </footer>
    </main>
</div>

@code {
    // Preparado para la lógica futura
    // Aquí se inyectarían los servicios para cargar las estadísticas reales
}
